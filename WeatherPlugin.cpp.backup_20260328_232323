void WeatherPlugin::Update(float deltaTime) {
    size_t now = GetTickCount64();
    if (now - m_lastUpdateTime < 10 * 60 * 1000 && m_lastUpdateTime != 0) {
        return;
    }
    FetchWeather();
}


// Overload: char* version (converts to wchar_t and calls the wchar_t version)
// HTTP GET - accepts const char* host and path, converts to wchar_t internally
// HTTP GET - 升级版：支持 HTTP 和 HTTPS
static std::string HttpGet(const char* host, const char* path, bool useHttps = false) {
    std::string response;

    // 宽字符转换
    int hlen = MultiByteToWideChar(CP_UTF8, 0, host, -1, NULL, 0);
    std::wstring whost;
    if (hlen > 0) { whost.resize(hlen - 1); MultiByteToWideChar(CP_UTF8, 0, host, -1, &whost[0], hlen); }

    int plen = MultiByteToWideChar(CP_UTF8, 0, path, -1, NULL, 0);
    std::wstring wpath;
    if (plen > 0) { wpath.resize(plen - 1); MultiByteToWideChar(CP_UTF8, 0, path, -1, &wpath[0], plen); }

    // 把原来的 L"DynamicIsland/1.0" 换成标准的 Chrome 浏览器标识
    HINTERNET hSession = WinHttpOpen(L"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        WINHTTP_ACCESS_TYPE_NO_PROXY, WINHTTP_NO_PROXY_NAME, WINHTTP_NO_PROXY_BYPASS, 0);
    if (!hSession) return response;

    // 【关键修复】：设置极速超时（解析、连接、发送、接收），全设为 3000 毫秒。
    // 这样哪怕 API 彻底瘫痪，最多 3 秒就会报错释放，绝对不会把程序挂死！
    WinHttpSetTimeouts(hSession, 3000, 3000, 3000, 3000);

    // 动态判断端口 (HTTPS 为 443, HTTP 为 80)
    INTERNET_PORT port = useHttps ? INTERNET_DEFAULT_HTTPS_PORT : INTERNET_DEFAULT_HTTP_PORT;
    HINTERNET hConnect = WinHttpConnect(hSession, whost.c_str(), port, 0);
    if (!hConnect) { WinHttpCloseHandle(hSession); return response; }

    // 动态添加 HTTPS 安全协议标志
    DWORD flags = useHttps ? WINHTTP_FLAG_SECURE : 0;
    HINTERNET hRequest = WinHttpOpenRequest(hConnect, L"GET", wpath.c_str(), NULL, WINHTTP_NO_REFERER, WINHTTP_DEFAULT_ACCEPT_TYPES, flags);
    if (!hRequest) { WinHttpCloseHandle(hConnect); WinHttpCloseHandle(hSession); return response; }

    if (WinHttpSendRequest(hRequest, WINHTTP_NO_ADDITIONAL_HEADERS, 0, WINHTTP_NO_REQUEST_DATA, 0, 0, 0)) {
        if (WinHttpReceiveResponse(hRequest, NULL)) {
            DWORD size = 0;
            do {
                if (!WinHttpQueryDataAvailable(hRequest, &size) || size == 0) break;
                std::string buf;
                buf.resize(size);
                DWORD downloaded = 0;
                if (WinHttpReadData(hRequest, &buf[0], size, &downloaded)) {
                    buf.resize(downloaded);
                    response += buf;
                }
            } while (size > 0);
        }
    }
    WinHttpCloseHandle(hRequest);
    WinHttpCloseHandle(hConnect);
    WinHttpCloseHandle(hSession);
    return response;
}
void WeatherPlugin::FetchWeather() {
    static std::atomic<bool> isFetching{ false };
    if (isFetching) return;
    isFetching = true;

    m_lastUpdateTime = GetTickCount64();

    std::thread([this]() {
        // 城市显示名（含区/县等信息，供UI展示用）
        std::wstring cityDisplayName = L"长沙市岳麓区";

        // wttr.in API 查询城市名（用拼音，不支持中文行政区划）
        std::string myCity = "Changsha"; // <--- 改成你的城市拼音

        // 2. 访问极客接口 (永远免费，没有 Key 限流的问题)
        std::string apiPath = "/" + myCity + "?format=%25C|%25t";
        std::string resp = HttpGet("wttr.in", apiPath.c_str(), true);

        if (!resp.empty()) {
            OutputDebugStringA(("[Weather] wttr.in 原始返回: " + resp + "\n").c_str());

            size_t barPos = resp.find("|");
            if (barPos != std::string::npos) {
                std::string condition = resp.substr(0, barPos);
                std::string tempStr = resp.substr(barPos + 1);

                // --- 翻译天气状态，拼接城市名 ---
                std::wstring wDesc(condition.length(), L' ');
                std::copy(condition.begin(), condition.end(), wDesc.begin());
                m_description = cityDisplayName + L" " + wDesc;

                // --- 暴力提取温度 ---
                // 不管后面跟的是 °C 还是 掳C 乱码，我们只把数字和负号抠出来
                std::string cleanTemp;
                for (char c : tempStr) {
                    if ((c >= '0' && c <= '9') || c == '-' || c == '.') {
                        cleanTemp += c;
                    }
                }

                if (!cleanTemp.empty()) {
                    m_temperature = (float)std::atof(cleanTemp.c_str());

                    wchar_t dbg[128];
                    swprintf_s(dbg, L"[Weather] 解析出的纯净温度: %.1f\n", m_temperature);
                    OutputDebugStringW(dbg);
                }
            }
        }
        isFetching = false;
        }).detach();
}

